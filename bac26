function renderResult(r){
  hideAll();
  const box=document.getElementById('resultBox');
  const st=r.status||'fail';
  const moyNum=(r.moy_bac!=null&&r.moy_bac!=='')?Number(r.moy_bac):null;
  const moy=moyNum!=null?moyNum.toFixed(2):'—';
  const pct=moyNum!=null?Math.max(0,Math.min(100,(moyNum/20)*100)):0;
  function row(ic,k,v){return '<div class="rc-row"><span class="rc-k">'+ROW_ICONS[ic]+k+'</span><span class="rc-v">'+esc(v||'—')+'</span></div>';}
  box.className='rc rc-st-'+st+' show';
  box.innerHTML=
    '<div class="rc-card" id="rcCard">'+
      '<div class="rc-celebrate"><span class="ce-spark">🎉</span> مبروك النجاح! <span class="ce-spark">🎉</span></div>'+
      '<div class="rc-head">'+
        '<div class="rc-head-main">'+
          '<div class="rc-name">'+esc(r.nom_ar||r.nom_fr||'—')+'</div>'+
          '<div class="rc-serie">'+esc(r.serie_ar||'')+'</div>'+
        '</div>'+
        '<div class="rc-emblem">'+(EMBLEM[st]||EMBLEM.fail)+'</div>'+
        '<span class="rc-decision">'+esc(r.decision_ar||'—')+'</span>'+
      '</div>'+
      '<div class="rc-rows">'+
        '<div class="rc-row moy"><span class="rc-k">'+ROW_ICONS.moy+'المعدل</span><span class="rc-v">'+moy+' <small>/ 20</small></span></div>'+
      '</div>'+
      (moyNum!=null?'<div class="rc-moybar"><div class="rc-moybar-fill" id="moybar"></div></div>':'')+
      '<div class="rc-rows" style="padding-top:0">'+
        row('wilaya','الولاية', r.wilaya_ar)+
        row('centre','مركز الامتحان', r.centre_ar)+
        row('etab','المؤسسة', r.etab_ar)+
      '</div>'+
      '<div class="rc-foot"><img class="rc-foot-img rc-foot-light" alt="maurinote" src="'+RC_LOGO_LIGHT+'"><img class="rc-foot-img rc-foot-dark" alt="maurinote" src="'+RC_LOGO_DARK+'"></div>'+
    '</div>'+
    '<div class="rc-share">'+
      '<button class="share-btn primary" id="shareImgBtn" onclick="shareImage()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5 15.4 17.5M15.4 6.5 8.6 10.5"/></svg> مشاركة الصورة</button>'+
      '<button class="share-btn" onclick="copyLink(\''+esc(r.nodoss)+'\')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg> نسخ الرابط</button>'+
    '</div>';
  box.scrollIntoView({behavior:'smooth',block:'center'});
  if(st==='pass'){setTimeout(celebrate,300);}
  // update URL so it's shareable
  try{history.replaceState(null,'','?n='+encodeURIComponent(r.nodoss));}catch(e){}
  // animate progress bar
  if(moyNum!=null){
    requestAnimationFrame(()=>requestAnimationFrame(()=>{
      const bar=document.getElementById('moybar');
      if(bar)bar.style.width=pct+'%';
    }));
  }
}

function celebrate(){
  const colors=['#ffcc00','#fb275d','#00b775','#0f9d6e','#ffd84d'];
  const cv=document.createElement('canvas');
  cv.style.cssText='position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:300';
  document.body.appendChild(cv);
  const ctx=cv.getContext('2d');
  function size(){cv.width=innerWidth*devicePixelRatio;cv.height=innerHeight*devicePixelRatio;ctx.setTransform(devicePixelRatio,0,0,devicePixelRatio,0,0);}
  size();
  const N=Math.min(170,Math.round(innerWidth/3)),parts=[];
  for(let i=0;i<N;i++){parts.push({x:Math.random()*innerWidth,y:-20-Math.random()*innerHeight*0.4,r:6+Math.random()*7,c:colors[i%colors.length],vx:(Math.random()-0.5)*2.4,vy:3+Math.random()*4.5,rot:Math.random()*Math.PI,vr:(Math.random()-0.5)*0.32,shape:Math.random()<0.5?'rect':'circ'});}
  const start=performance.now(),dur=2800;
  function frame(t){const el=t-start;ctx.clearRect(0,0,innerWidth,innerHeight);parts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=0.045;p.rot+=p.vr;ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rot);ctx.globalAlpha=Math.max(0,1-el/dur);ctx.fillStyle=p.c;if(p.shape==='rect'){ctx.fillRect(-p.r/2,-p.r/2,p.r,p.r*0.62);}else{ctx.beginPath();ctx.arc(0,0,p.r/2,0,7);ctx.fill();}ctx.restore();});if(el<dur){requestAnimationFrame(frame);}else{cv.remove();}}
  requestAnimationFrame(frame);
}

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  clearTimeout(window._tt);window._tt=setTimeout(()=>t.classList.remove('show'),2200);
}

function copyLink(nodoss){
  const url=location.origin+location.pathname+'?n='+encodeURIComponent(nodoss);
  if(navigator.clipboard&&navigator.clipboard.writeText){
    navigator.clipboard.writeText(url).then(()=>toast('تم نسخ الرابط')).catch(()=>toast('تعذّر النسخ'));
  }else{
    const ta=document.createElement('textarea');ta.value=url;document.body.appendChild(ta);ta.select();
    try{document.execCommand('copy');toast('تم نسخ الرابط');}catch(e){toast('تعذّر النسخ');}
    document.body.removeChild(ta);
  }
}

async function shareImage(){
  const card=document.getElementById('rcCard');
  const btn=document.getElementById('shareImgBtn');
  if(!card||typeof html2canvas==='undefined'){toast('تعذّر إنشاء الصورة');return;}
  const orig=btn.innerHTML;
  btn.disabled=true;btn.innerHTML='<span class="sb-spin"></span> جارٍ التجهيز';
  const dark=document.documentElement.getAttribute('data-theme')==='dark';
  try{
    const canvas=await html2canvas(card,{scale:2,backgroundColor:dark?'#152120':'#ffffff',useCORS:true,logging:false});
    const blob=await new Promise(res=>canvas.toBlob(res,'image/png'));
    const safe=(document.querySelector('.rc-name')?document.querySelector('.rc-name').textContent.trim():'نتيجة').replace(/\s+/g,'_');
    const file=new File([blob],'نتيجة_'+safe+'.png',{type:'image/png'});
    if(navigator.canShare&&navigator.canShare({files:[file]})){
      try{await navigator.share({files:[file],title:'نتيجتي في البكالوريا',text:'نتيجتي عبر maurinote'});}
      catch(e){/* المستخدم ألغى المشاركة */}
    }else{
      const url=URL.createObjectURL(blob);
      const a=document.createElement('a');a.href=url;a.download=file.name;
      document.body.appendChild(a);a.click();document.body.removeChild(a);
      setTimeout(()=>URL.revokeObjectURL(url),1000);
      toast('تم حفظ الصورة — المشاركة غير مدعومة هنا');
    }
  }catch(e){
    toast('تعذّر إنشاء الصورة');
  }
  btn.disabled=false;btn.innerHTML=orig;
}

async function searchResult(num){
  num=String(num).replace(/[^0-9]/g,'');
  if(num.length<5)num=num.padStart(5,'0');
  setLoading(true);
  try{
    const url=SUPABASE_URL.replace(/\/$/,'')+'/rest/v1/'+RESULTS_TABLE+'?nodoss=eq.'+encodeURIComponent(num)+'&select=*';
    const res=await fetch(url,{headers:{'apikey':SUPABASE_ANON_KEY,'Authorization':'Bearer '+SUPABASE_ANON_KEY}});
    setLoading(false);
    if(!res.ok){showMsg('err','تعذّر جلب النتيجة','حدث خطأ في الاتصال. تأكد من الإنترنت وحاول مرة أخرى.');return;}
    const data=await res.json();
    if(!data||!data.length){showMsg('warn','لا توجد نتيجة بهذا الرقم','تأكد من رقم الترشح <b>'+esc(num)+'</b> كما في بطاقة الامتحان وحاول مجددًا.');return;}
    renderResult(data[0]);
  }catch(e){
    setLoading(false);
    showMsg('err','تعذّر جلب النتيجة','حدث خطأ في الاتصال. تأكد من الإنترنت وحاول مرة أخرى.');
  }
}

/* auto-load result if ?n= in URL (shareable links) */
(function(){
  try{
    const params=new URLSearchParams(location.search);
    const n=params.get('n');
    if(n){const clean=n.replace(/[^0-9]/g,'');if(clean){document.getElementById('searchInput').value=clean;searchResult(clean);}}
  }catch(e){}
})();
</script>
