<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>شهادة البكالوريا – الدورة العادية 2026 · نتائجنا</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D%27http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%27%20viewBox%3D%270%200%20109.14%20137.14%27%3E%3Crect%20y%3D%2755.41%27%20width%3D%27109.14%27%20height%3D%2739.58%27%20fill%3D%27%23fc0%27%2F%3E%3Crect%20x%3D%2739.94%27%20y%3D%27111.71%27%20width%3D%2769.2%27%20height%3D%2725.43%27%20fill%3D%27%23fb275d%27%2F%3E%3Ccircle%20cx%3D%2789.8%27%20cy%3D%2719.34%27%20r%3D%2719.34%27%20fill%3D%27%2300b775%27%2F%3E%3C%2Fsvg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
:root{
  --bg:#f7faf9;
  --bg-tint:#eef4f2;
  --panel:#ffffff;
  --panel-2:#f3f7f6;
  --line:#e4ecea;
  --line-2:#d3e0dc;
  --ink:#102a23;
  --ink-2:#52665f;
  --ink-3:#90a39c;
  --green:#0f9d6e;
  --green-deep:#0a7d57;
  --green-soft:#e7f6f0;
  --green-line:#c7e8dc;
  --t1:#0f9d6e; --t1s:#e7f6f0; --t1l:#c7e8dc;
  --t2:#0d9488; --t2s:#e2f4f1; --t2l:#bfe5df;
  --t3:#3f7d6e; --t3s:#e9f1ee; --t3l:#cfe0da;
  --t4:#5b7c87; --t4s:#eaf1f3; --t4l:#cfe0e4;
  --amber:#d97706; --amber-soft:#fef3e2; --amber-line:#f6dcb0;
  --red:#dc2626; --red-soft:#fdecec; --red-line:#f6c9c9;
  --mint:#9fe3c4; --mint-soft:#d6f3e6; --mint-deep:#1d6e56;
  --beige:#f6c98a; --beige-soft:#fdedd4; --beige-line:#f3d9ab;
  --navy:#10342a;
  --radius:18px;
  --maxw:1320px;
}
[data-theme="dark"]{
  --bg:#0d1513;
  --bg-tint:#101b18;
  --panel:#152120;
  --panel-2:#1a2826;
  --line:#243431;
  --line-2:#31453f;
  --ink:#e9f2ef;
  --ink-2:#a7bab3;
  --ink-3:#728a82;
  --green:#1cc08a;
  --green-deep:#16a877;
  --green-soft:#103328;
  --green-line:#1d4d3c;
  --t1:#1cc08a; --t1s:#103328; --t1l:#1d4d3c;
  --t2:#19b4a5; --t2s:#0e3330; --t2l:#1c4d48;
  --t3:#6fb39f; --t3s:#16302a; --t3l:#244a40;
  --t4:#84a8b3; --t4s:#16282d; --t4l:#274046;
  --amber:#f59e0b; --amber-soft:#3a2c12; --amber-line:#5e4719;
  --red:#f87171; --red-soft:#3a1c1c; --red-line:#5e2a2a;
  --mint:#1f7d60; --mint-soft:#143a2e; --mint-deep:#7fd9b5;
  --beige:#c98f4a; --beige-soft:#3a2c16; --beige-line:#5e4719;
  --navy:#0c2820;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:hidden;max-width:100%}
body{font-family:'Rubik',sans-serif;background:var(--bg);color:var(--ink);line-height:1.75;overflow-x:hidden;max-width:100%;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s;font-feature-settings:"lnum"}
::selection{background:var(--green);color:#fff}

.bg-layer{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;width:100%;max-width:100vw}
.bg-orb{position:absolute;border-radius:50%;filter:blur(85px)}
.orb-1{width:480px;height:480px;background:radial-gradient(circle,rgba(15,157,110,.14),transparent 70%);top:-180px;right:-120px}
.orb-2{width:420px;height:420px;background:radial-gradient(circle,rgba(13,148,136,.11),transparent 70%);top:34%;left:-160px}
.orb-3{width:360px;height:360px;background:radial-gradient(circle,rgba(15,157,110,.08),transparent 70%);bottom:6%;right:8%}

.wrap{position:relative;z-index:1;max-width:var(--maxw);margin:0 auto;padding:0 24px}

/* top bar */
header{position:sticky;top:0;z-index:50;backdrop-filter:blur(16px);background:var(--panel);border-bottom:1px solid var(--line);transition:background .3s,border-color .3s}
header.scrolled{background:color-mix(in srgb,var(--panel) 85%,transparent)}
.nav{max-width:var(--maxw);margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;position:relative}
.nav-right{flex:1 1 0;display:flex;align-items:center;justify-content:flex-end;gap:10px;min-width:0}
.brand-center{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);display:inline-flex;align-items:center;line-height:0;text-decoration:none}
.wm{height:36px;width:auto;display:block}
.wm-dark{display:none}
[data-theme="dark"] .wm-light{display:none}
[data-theme="dark"] .wm-dark{display:block}
.nav-links{display:flex;align-items:center;gap:4px}
.nav-links a{color:var(--ink-2);text-decoration:none;font-size:.86rem;font-weight:500;padding:8px 13px;border-radius:9px;transition:.2s}
.nav-links a:hover{color:var(--ink);background:var(--panel-2)}
.nav-cta{background:var(--green)!important;color:#fff!important;font-weight:600!important}
.nav-cta:hover{background:var(--green-deep)!important}
.theme-btn{width:40px;height:40px;border-radius:11px;flex-shrink:0;background:var(--panel-2);border:1px solid var(--line);color:var(--ink-2);display:grid;place-items:center;cursor:pointer;transition:.2s}
.theme-btn:hover{color:var(--ink);border-color:var(--line-2)}
.theme-btn svg{width:19px;height:19px}
.theme-btn .sun{display:none}
[data-theme="dark"] .theme-btn .moon{display:none}
[data-theme="dark"] .theme-btn .sun{display:block}
.menu-btn{display:none;background:none;border:none;color:var(--ink);cursor:pointer}

/* hero */
.hero{padding:54px 0 14px;text-align:center;position:relative}
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:.78rem;font-weight:500;color:var(--green-deep);background:var(--green-soft);border:1px solid var(--green-line);padding:7px 16px;border-radius:999px;margin-bottom:20px}
.pulse{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(15,157,110,.45)}70%{box-shadow:0 0 0 8px rgba(15,157,110,0)}100%{box-shadow:0 0 0 0 rgba(15,157,110,0)}}
.hero h1{font-size:clamp(1.7rem,4.6vw,2.7rem);font-weight:800;letter-spacing:-.025em;line-height:1.2;margin-bottom:16px;color:var(--ink)}
.hero h1 span{color:var(--green)}
.hero p.lead{font-size:clamp(.95rem,2.1vw,1.08rem);color:var(--ink-2);max-width:560px;margin:0 auto;font-weight:300}
.hero p.lead-2{font-size:clamp(1.05rem,2.4vw,1.25rem);color:var(--green-deep);max-width:560px;margin:14px auto 0;font-weight:600;display:flex;align-items:center;justify-content:center;gap:9px}
.hero p.lead-2 .lead-ic{width:22px;height:22px;flex-shrink:0;color:var(--green)}

/* ==== competition lanes (each on its own full-width row) ==== */
.lanes-sec{padding:42px 0 56px}
.lanes-head{max-width:920px;margin:0 auto 22px}
.lanes-head .lh-txt{text-align:right}
.lanes-head h2{font-size:clamp(1.35rem,3.2vw,1.9rem);font-weight:700;letter-spacing:-.02em;color:var(--ink)}
.lanes-head .lh-desc{font-size:.92rem;color:var(--ink-2);font-weight:300;margin-top:6px;max-width:520px}

.lanes{max-width:920px;margin:0 auto;display:flex;flex-direction:column;gap:22px}
.lane{display:flex;align-items:center;gap:20px;background:var(--panel);border:1px solid var(--line);border-radius:20px;padding:20px 24px;text-decoration:none;color:inherit;position:relative;overflow:hidden;transition:transform .22s,border-color .22s,box-shadow .22s}
.lane::before{content:"";position:absolute;top:0;bottom:0;right:0;width:5px;background:var(--ln);transition:width .22s}
.lane:hover{transform:translateY(-2px);border-color:var(--line-2);box-shadow:0 20px 44px -28px rgba(10,60,42,.4)}
.lane:hover::before{width:8px}
.lane:focus-visible{outline:2px solid var(--green);outline-offset:3px}

.lane-abbr-box{width:128px;height:60px;flex-shrink:0;display:grid;place-items:center;background:var(--ln-soft);border:1px solid var(--ln-line);border-radius:14px;color:var(--ln);font-weight:800;font-size:.95rem;letter-spacing:.05em}

.lane-body{flex:1;min-width:0;text-align:right}
.lane-title{font-size:1.12rem;font-weight:700;color:var(--ink);line-height:1.4}

.lane-go{flex-shrink:0;display:inline-flex;align-items:center;gap:7px;font-size:.88rem;font-weight:700;padding:10px 18px;border-radius:999px;white-space:nowrap;transition:.22s}
.lane-go svg{width:16px;height:16px;transition:.22s}
.lane-go.soon{color:var(--amber);background:var(--amber-soft);border:1px solid var(--amber-line)}
.lane-go.live{color:var(--green-deep);background:var(--green-soft);border:1px solid var(--green-line)}
.lane-go.live .dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
.lane:hover .lane-go svg{transform:rotate(-18deg)}

/* per-lane color theming */
.lane.bac{--ln:var(--green-deep);--ln-soft:var(--green-soft);--ln-line:var(--green-line)}
.lane.brevet{--ln:#b9772a;--ln-soft:var(--beige-soft);--ln-line:var(--beige-line)}
.lane.concours{--ln:var(--t2);--ln-soft:var(--t2s);--ln-line:var(--t2l)}

/* sections */
section{padding:56px 0;position:relative}
.sec-head{text-align:center;margin-bottom:32px}
.sec-tag{font-size:.78rem;font-weight:600;color:var(--green);letter-spacing:.06em;margin-bottom:10px}
.sec-head h2{font-size:clamp(1.5rem,3.6vw,2.1rem);font-weight:700;letter-spacing:-.02em;margin-bottom:8px;color:var(--ink)}
.sec-head h2.cd-title{font-size:clamp(1.15rem,2.6vw,1.55rem)}
.sec-head p{color:var(--ink-2);font-weight:300;max-width:520px;margin:0 auto}

/* countdown */
.cd-grid{display:flex;flex-direction:column;gap:10px;max-width:680px;margin:0 auto}
.cd-row{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:18px 22px;transition:.22s;position:relative}
.cd-row:hover{border-color:var(--line-2);box-shadow:0 14px 30px -26px rgba(10,60,42,.3)}
.cd-top{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:14px}
.cd-info{text-align:right;min-width:0}
.cd-title{font-size:.96rem;font-weight:600;color:var(--ink);line-height:1.35}
.cd-date{font-size:.76rem;color:var(--ink-3);margin-top:2px}
.cd-count{text-align:left;flex-shrink:0;display:flex;flex-direction:column;align-items:flex-start;gap:5px;line-height:1.1;min-width:130px}
.cd-num{font-size:2rem;font-weight:800;letter-spacing:-.02em;color:var(--green-deep)}
.cd-clock{font-size:1.75rem;font-weight:800;direction:ltr;font-variant-numeric:tabular-nums;letter-spacing:.02em;color:var(--green-deep)}
.cd-unit{font-size:.72rem;color:var(--ink-3);font-weight:500}
.cd-bar{height:6px;border-radius:999px;background:var(--line);overflow:hidden;position:relative}
.cd-bar-fill{position:absolute;inset:0 auto 0 0;right:0;left:auto;height:100%;border-radius:999px;background:var(--green);transition:width 1s linear;width:0}
.cd-done-badge{display:inline-block;font-size:.74rem;font-weight:600;padding:5px 14px;border-radius:999px;background:var(--green-soft);color:var(--green-deep);border:1px solid var(--green-line)}
.cd-row.a1 .cd-num,.cd-row.a1 .cd-clock{color:var(--mint-deep)} .cd-row.a1 .cd-bar-fill{background:var(--mint-deep)}
.cd-row.a2 .cd-num,.cd-row.a2 .cd-clock{color:#b9772a} .cd-row.a2 .cd-bar-fill{background:var(--beige)}
.cd-row.a3 .cd-num,.cd-row.a3 .cd-clock{color:var(--t3)} .cd-row.a3 .cd-bar-fill{background:var(--t3)}
.cd-row.a4 .cd-num,.cd-row.a4 .cd-clock{color:var(--t4)} .cd-row.a4 .cd-bar-fill{background:var(--t4)}
.cd-row.passed{background:var(--green-soft);border-color:var(--green-line)}
.cd-row.passed .cd-bar-fill{width:100%!important}

/* faq */
.faq-list{max-width:720px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.faq-item{background:var(--panel);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:.2s}
.faq-item:hover{border-color:var(--line-2)}
.faq-q{width:100%;background:none;border:none;color:var(--ink);font-family:inherit;font-size:1rem;font-weight:500;text-align:right;cursor:pointer;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px}
.faq-q svg{flex-shrink:0;color:var(--green);transition:.3s}
.faq-item.open .faq-q svg{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:.35s ease}
.faq-a p{padding:0 22px 20px;color:var(--ink-2);font-weight:300;font-size:.9rem;line-height:1.7}

/* footer */
footer{border-top:1px solid var(--line);padding:46px 0 28px;position:relative;z-index:1;margin-top:24px;background:var(--panel)}
.foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;margin-bottom:32px}
.foot-brand .brand{margin-bottom:14px}
.foot-brand p{color:var(--ink-2);font-size:.9rem;font-weight:300;max-width:340px;line-height:1.7}
.foot-col h5{font-size:.82rem;font-weight:600;color:var(--ink);margin-bottom:14px;letter-spacing:.04em}
.foot-col a{display:block;color:var(--ink-3);text-decoration:none;font-size:.88rem;padding:5px 0;transition:.2s;cursor:pointer}
.foot-col a:hover{color:var(--green-deep)}
.foot-social{display:flex;gap:10px;margin-top:18px}
.foot-social a{width:38px;height:38px;border-radius:10px;background:var(--panel-2);border:1px solid var(--line);display:grid;place-items:center;color:var(--ink-2);transition:.2s}
.foot-social a:hover{color:var(--green-deep);border-color:var(--line-2)}
.foot-social svg{width:18px;height:18px}
.foot-bottom{border-top:1px solid var(--line);padding-top:22px;text-align:center;color:var(--ink-3);font-size:.82rem}
.foot-bottom b{color:var(--ink-2);font-weight:500}

@media(max-width:980px){
  .foot-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:680px){
  .nav-links{display:none}
  .wm{height:28px}
  .foot-grid{grid-template-columns:1fr}
  section{padding:48px 0}
  .wrap{padding:0 16px}
  /* lanes: clean stacked card, centered */
  .lane{flex-direction:column;gap:12px;padding:20px 18px;align-items:center;text-align:center}
  .lane::before{width:4px}
  .lane:hover::before{width:6px}
  .lane-abbr-box{width:118px;height:48px;border-radius:12px;font-size:.82rem}
  .lane-body{flex:none;width:100%;text-align:center}
  .lane-title{font-size:1rem;line-height:1.5}
  .lane-go{width:100%;justify-content:center;order:3;padding:12px}
  .lanes-head{justify-content:center}
  .lanes-head .lh-txt{text-align:center;width:100%}
  /* countdown rows */
  .cd-row{padding:16px}
  .cd-top{gap:12px;margin-bottom:12px}
  .cd-title{font-size:.92rem}
  .cd-count{min-width:auto;align-items:flex-start}
  .cd-num{font-size:1.7rem}
  .cd-clock{font-size:1.45rem}
}
</style>

<style>
body.bac{--ln:var(--green-deep);--ln-soft:var(--green-soft);--ln-line:var(--green-line)}
body.brevet{--ln:#b9772a;--ln-soft:var(--beige-soft);--ln-line:var(--beige-line)}
body.concours{--ln:var(--t2);--ln-soft:var(--t2s);--ln-line:var(--t2l)}

.back-link{display:inline-flex;align-items:center;gap:7px;color:var(--ink-2);text-decoration:none;font-size:.88rem;font-weight:500;padding:8px 0;transition:.2s}
.back-link:hover{color:var(--green-deep)}
.back-link svg{width:16px;height:16px}
.back-row{max-width:560px;margin:0 auto 18px;text-align:right}

/* page header */
.page-hero{padding:28px 0 8px;text-align:center}
.page-state{display:inline-flex;align-items:center;gap:8px;font-size:.82rem;font-weight:600;padding:7px 16px;border-radius:999px;color:var(--green-deep);background:var(--green-soft);border:1px solid var(--green-line);margin-bottom:16px}
.page-hero h1{font-size:clamp(1.4rem,3.6vw,2rem);font-weight:800;letter-spacing:-.02em;color:var(--ink);line-height:1.3}
.page-sub{display:block;font-size:.6em;font-weight:500;color:var(--ink-3);letter-spacing:0;margin-top:5px}
.page-state .live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:livePulse 2s infinite}
@keyframes livePulse{0%{box-shadow:0 0 0 0 rgba(15,157,110,.5)}70%{box-shadow:0 0 0 7px rgba(15,157,110,0)}100%{box-shadow:0 0 0 0 rgba(15,157,110,0)}}

/* search */
.search-sec{padding:34px 0 60px}
.finder{max-width:560px;margin:0 auto;background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:26px 24px}
.finder h3{font-size:1.1rem;font-weight:700;color:var(--ink);margin-bottom:5px;text-align:center}
.finder .fsub{font-size:.85rem;color:var(--ink-3);text-align:center;margin-bottom:20px}
.entry-row{display:flex;gap:10px;align-items:stretch}
.input-wrap{flex:1;position:relative;display:flex;align-items:center}
.input-wrap>svg{position:absolute;right:15px;width:18px;height:18px;color:var(--ink-3);pointer-events:none}
.entry-row input{width:100%;background:var(--panel-2);border:1.5px solid var(--line-2);border-radius:11px;padding:13px 44px 13px 16px;color:var(--ink);font-family:inherit;font-size:1rem;font-weight:600;transition:.2s}
.entry-row input::placeholder{color:var(--ink-3);font-weight:400;font-size:.92rem}
.entry-row input:focus{outline:none;border-color:var(--green);background:var(--panel);box-shadow:0 0 0 3px var(--green-soft)}
.search-btn{background:var(--green-deep);color:#fff;border:none;border-radius:11px;font-family:inherit;font-size:.94rem;font-weight:700;cursor:pointer;padding:0 24px;transition:.2s;display:flex;align-items:center;gap:8px;white-space:nowrap}
.search-btn:hover:not(:disabled){background:var(--green)}
.search-btn:disabled{opacity:.7;cursor:not-allowed}
.search-btn svg{width:17px;height:17px}
.btn-spin{width:17px;height:17px;border:2.5px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:rcspin .7s linear infinite}
@keyframes rcspin{to{transform:rotate(360deg)}}
.entry-hint{text-align:center;color:var(--ink-3);font-size:.8rem;margin-top:14px}

/* result card */
.rc{max-width:560px;margin:20px auto 0;display:none}
.rc.show{display:block;animation:rcIn .25s ease}
@keyframes rcIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.rc-card{background:var(--panel);border:1px solid var(--line);border-radius:18px;overflow:hidden;box-shadow:0 12px 44px -20px rgba(16,42,35,.28)}
.rc-st-pass .rc-card{border-color:var(--green-line);box-shadow:0 14px 54px -18px rgba(0,183,117,.5)}
.rc-celebrate{display:none}
.rc-st-pass .rc-celebrate{display:flex;align-items:center;justify-content:center;gap:9px;padding:14px 18px;font-weight:800;font-size:1.06rem;color:#fff;background:linear-gradient(105deg,#00b775,#0f9d6e);letter-spacing:.02em;animation:celebPop .45s cubic-bezier(.2,1.3,.4,1)}
.rc-celebrate .ce-spark{font-size:1.15rem;animation:ceFloat 1.6s ease-in-out infinite}
.rc-emblem{width:74px;height:74px;border-radius:50%;display:grid;place-items:center;margin:2px auto}
.rc-emblem svg{width:40px;height:40px}
.rc-st-pass .rc-emblem{background:linear-gradient(145deg,#00b775,#0f9d6e);color:#fff;box-shadow:0 10px 24px -6px rgba(0,183,117,.6);animation:emblemPop .5s cubic-bezier(.2,1.4,.4,1)}
.rc-st-fail .rc-emblem{background:#fdecec;color:#dc2626;border:2px solid #f6c9c9}
.rc-st-session .rc-emblem{background:#fef3e2;color:#b45309;border:2px solid #f6dcb0}
.rc-st-absent .rc-emblem,.rc-st-cancel .rc-emblem{background:var(--panel-2);color:var(--ink-3);border:2px solid var(--line-2)}
[data-theme="dark"] .rc-st-fail .rc-emblem{background:#3a1c1c;color:#f87171;border-color:#5e2a2a}
[data-theme="dark"] .rc-st-session .rc-emblem{background:#3a2c12;color:#f59e0b;border-color:#5e4719}
@keyframes emblemPop{from{transform:scale(.55);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes celebPop{from{transform:scale(.92);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes ceFloat{0%,100%{transform:translateY(0) rotate(-6deg)}50%{transform:translateY(-3px) rotate(6deg)}}
.rc-head{padding:24px 24px 20px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:11px;border-bottom:1px solid var(--line)}
.rc-head-main{width:100%;min-width:0}
.rc-name{font-size:1.34rem;font-weight:800;color:var(--ink);line-height:1.4;margin-bottom:5px}
.rc-serie{font-size:.85rem;color:var(--ink-3);font-weight:500}
.rc-decision{flex-shrink:0;display:inline-flex;align-items:center;gap:7px;font-size:.88rem;font-weight:700;padding:8px 16px;border-radius:10px;white-space:nowrap}
.rc-decision svg{width:16px;height:16px}
.rc-st-pass .rc-decision{color:var(--green-deep);background:var(--green-soft);border:1px solid var(--green-line)}
.rc-st-session .rc-decision{color:#b45309;background:#fef3e2;border:1px solid #f6dcb0}
.rc-st-fail .rc-decision{color:#b91c1c;background:#fdecec;border:1px solid #f6c9c9}
.rc-st-absent .rc-decision,.rc-st-cancel .rc-decision{color:var(--ink-2);background:var(--panel-2);border:1px solid var(--line-2)}
[data-theme="dark"] .rc-st-session .rc-decision{color:#f59e0b;background:#3a2c12;border-color:#5e4719}
[data-theme="dark"] .rc-st-fail .rc-decision{color:#f87171;background:#3a1c1c;border-color:#5e2a2a}
.rc-rows{padding:6px 24px 12px}
.rc-row{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:13px 0;border-bottom:1px solid var(--line)}
.rc-row:last-child{border-bottom:none}
.rc-row .rc-k{font-size:.86rem;color:var(--ink-3);font-weight:500;flex-shrink:0}
.rc-row .rc-v{font-size:.95rem;color:var(--ink);font-weight:700;text-align:left}
.rc-row.moy .rc-v{font-size:1.5rem;font-weight:800;letter-spacing:-.01em}
.rc-st-pass .rc-row.moy .rc-v{color:var(--green-deep)}
.rc-st-session .rc-row.moy .rc-v{color:#b45309}
.rc-st-fail .rc-row.moy .rc-v{color:#b91c1c}
.rc-st-absent .rc-row.moy .rc-v,.rc-st-cancel .rc-row.moy .rc-v{color:var(--ink-2)}
[data-theme="dark"] .rc-st-session .rc-row.moy .rc-v{color:#f59e0b}
[data-theme="dark"] .rc-st-fail .rc-row.moy .rc-v{color:#f87171}
.rc-row.moy .rc-v small{font-size:.6rem;font-weight:600;color:var(--ink-3)}
.rc-foot{padding:16px 24px;background:var(--panel-2);display:flex;align-items:center;justify-content:center}
.rc-foot b{color:var(--ink-2);font-weight:700;letter-spacing:.03em}

/* icons in rows */
.rc-k{display:flex;align-items:center;gap:8px}
.rc-k svg{width:16px;height:16px;color:var(--ink-3);flex-shrink:0}
.rc-st-pass .rc-row.moy .rc-k svg{color:var(--green-deep)}

/* moy progress bar */
.rc-moybar{height:7px;border-radius:999px;background:var(--line);overflow:hidden;margin:0 24px 4px}
.rc-moybar-fill{height:100%;border-radius:999px;width:0;transition:width 1s cubic-bezier(.3,.9,.3,1)}
.rc-st-pass .rc-moybar-fill{background:var(--green)}
.rc-st-session .rc-moybar-fill{background:#d97706}
.rc-st-fail .rc-moybar-fill{background:#dc2626}
.rc-st-absent .rc-moybar-fill,.rc-st-cancel .rc-moybar-fill{background:var(--ink-3)}

/* share actions */
.rc-share{display:flex;gap:10px;max-width:560px;margin:14px auto 0}
.share-btn{flex:1;display:inline-flex;align-items:center;justify-content:center;gap:8px;font-family:inherit;font-size:.9rem;font-weight:700;padding:13px 16px;border-radius:12px;cursor:pointer;transition:.2s;border:1.5px solid var(--line-2);background:var(--panel);color:var(--ink)}
.share-btn:hover{border-color:var(--green);color:var(--green-deep)}
.share-btn svg{width:18px;height:18px}
.share-btn.primary{background:var(--green-deep);color:#fff;border-color:var(--green-deep)}
.share-btn.primary:hover{background:var(--green);color:#fff}
.share-btn:disabled{opacity:.6;cursor:not-allowed}
.share-btn .sb-spin{width:17px;height:17px;border:2.5px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:rcspin .7s linear infinite}

/* watermark brand (only visible in saved image) */
.rc-foot-img{height:26px;width:auto;display:block}
.rc-foot-dark{display:none}
[data-theme="dark"] .rc-foot-light{display:none}
[data-theme="dark"] .rc-foot-dark{display:block}

/* toast */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--ink);color:var(--bg);font-size:.88rem;font-weight:600;padding:12px 22px;border-radius:12px;opacity:0;transition:.3s;z-index:200;pointer-events:none;box-shadow:0 12px 30px -10px rgba(0,0,0,.4)}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* message (not found / error) */
.rc-msg{max-width:560px;margin:20px auto 0;display:none;background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:30px 24px;text-align:center}
.rc-msg.show{display:block;animation:rcIn .25s ease}
.rc-msg-ic{width:56px;height:56px;border-radius:50%;margin:0 auto 14px;display:grid;place-items:center}
.rc-msg-ic svg{width:28px;height:28px}
.rc-msg.warn .rc-msg-ic{background:var(--amber-soft);color:var(--amber)}
.rc-msg.err .rc-msg-ic{background:var(--red-soft);color:var(--red)}
.rc-msg h3{font-size:1.1rem;font-weight:700;color:var(--ink);margin-bottom:7px}
.rc-msg p{font-size:.89rem;color:var(--ink-2);font-weight:400;line-height:1.7}
.rc-msg p b{color:var(--ink);font-weight:700}

@media(max-width:680px){.entry-row{flex-direction:column}.search-btn{padding:13px;justify-content:center}}
@media(max-width:520px){.rc-name{font-size:1.18rem}.rc-head{gap:10px}}
@media(max-width:430px){.wm{height:21px}}
</style>

